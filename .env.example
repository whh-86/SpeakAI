FLASK_SECRET_KEY=replace-this-with-a-random-string
FLASK_DEBUG=true
PORT=5000

# ASR: local_whisper, deepgram, or openai
ASR_BACKEND=local_whisper
ASR_MODEL=tiny.en
ASR_LANGUAGE=en

# Deepgram ASR
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en
DEEPGRAM_LISTEN_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_STREAM_URL=wss://api.deepgram.com/v1/listen
DEEPGRAM_ENDPOINTING_MS=300

# Local Whisper ASR
WHISPER_CONDA_ENV=whisper-exp
WHISPER_PYTHON_EXE=
WHISPER_PRELOAD=false

# OpenAI ASR fallback
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# LLM provider: gemini or qwen
LLM_PROVIDER=gemini

# Gemini Developer API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Qwen / DashScope OpenAI-compatible API
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
# International endpoint. For mainland China DashScope, use:
# https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Vertex AI alternative (set GOOGLE_GENAI_USE_VERTEXAI=true if you use this path)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# TTS
EDGE_TTS_VOICE=en-US-AriaNeural

# App behavior
SYNTHESIZE_ON_CHAT=false
REQUEST_TIMEOUT_SECONDS=45
MAX_AUDIO_BYTES=26214400
AUDIO_UPLOAD_DIR=tmp
TTS_OUTPUT_DIR=static/audio
